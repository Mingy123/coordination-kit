# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y

# Flash — DFR1154 has W25Q128J (16MB), use 4MB for partition sizing
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# PSRAM — mandatory for camera frame buffers
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y

# CPU
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_ESP32S3_DEFAULT_CPU_FREQ_240=y

# USB (Synopsys DWC2 driver for TinyUSB)
CONFIG_USING_SYNOPSYS_DWC2_DRIVER=y

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Console over UART at 2Mbaud to keep USB free for UVC
CONFIG_ESP_CONSOLE_UART_CUSTOM=y
CONFIG_ESP_CONSOLE_UART_BAUDRATE=2000000
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y

# Camera module
CONFIG_CAMERA_MODULE_DFR1154=y

# UVC defaults
CONFIG_FORMAT_MJPEG_CAM1=y
CONFIG_FRAMESIZE_HD=y
CONFIG_UVC_CAM1_MULTI_FRAMESIZE=y
